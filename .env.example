# Example environment for the microservice backend.
# Copy to .env.development for local runs, or to .env if you prefer a single shared file.
# Do not set a global PORT here. Each service has its own port variable.

SPRING_PROFILES_ACTIVE=development
SPRING_DEVTOOLS_RESTART_ENABLED=true
SPRING_DEVTOOLS_LIVERELOAD_ENABLED=true

# Service discovery
EUREKA_SERVER_PORT=8761
EUREKA_DEFAULT_ZONE=http://localhost:8761/eureka/
EUREKA_HOST=localhost
EUREKA_PORT=8761
EUREKA_USER=
EUREKA_PASSWORD=

# Shared app settings
API_GATEWAY_PORT=9000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:9000,http://127.0.0.1:9000
SHOW_SQL=false

# JWT settings for auth-service and services that validate tokens.
AUTH_SERVICE_PORT=9004
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000
JWT_ISSUER=attendance-auth-service

# Auth service database
AUTH_DB_URL=jdbc:postgresql://localhost:5432/attendance_auth
AUTH_DB_USERNAME=attendance
AUTH_DB_PASSWORD=attendance

# HR service database
HR_SERVICE_PORT=9001
HR_DB_URL=jdbc:postgresql://localhost:5432/attendance_hr
HR_DB_USERNAME=attendance
HR_DB_PASSWORD=attendance
FACE_MATCH_DISTANCE_THRESHOLD=0.55

# Attendance service database
ATTENDANCE_SERVICE_PORT=9002
ATTENDANCE_DB_URL=jdbc:postgresql://localhost:5432/attendance_attendance
ATTENDANCE_DB_USERNAME=attendance
ATTENDANCE_DB_PASSWORD=attendance
MIN_CHECKOUT_AFTER_MINUTES=30
ATTENDANCE_KIOSK_TOKEN_EXPIRATION_SECONDS=300
ATTENDANCE_KIOSK_ALLOWED_CLOCK_SKEW_SECONDS=30
ATTENDANCE_KIOSK_NONCE_TTL_SECONDS=120

# Request service database
REQUEST_DB_USERNAME=attendance
REQUEST_DB_PASSWORD=attendance

# Monolith fallback database. Used only when running monolith-service.
MONOLITH_SERVICE_PORT=9010
DB_URL=jdbc:postgresql://localhost:5432/attendance_db
DB_USERNAME=attendance
DB_PASSWORD=attendance
SEED_DEFAULT_USERS=false
